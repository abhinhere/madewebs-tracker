generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum WorkType {
  WEBSITE
  LOGO
  POSTER
  BRANDING
  WEB_APP
  SEO
  MAINTENANCE
}

enum ProjectStatus {
  NEW
  PLANNING
  REPO
  DESIGNING
  DEVELOPING
  DEVELOPMENT
  PUSHED
  DEPLOYED
  REVIEW
  FINAL_CHANGES
  DOMAIN_CONNECTION
  REVISION
  TESTED
  COMPLETED
  DELIVERED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReviewStatus {
  PENDING_REVIEW
  CLIENT_REVIEWING
  CLIENT_APPROVED
  APPROVED
  CHANGES_REQUESTED
}

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
  OVERDUE
}

enum NotificationType {
  TASK_ASSIGNED
  DEADLINE_REMINDER
  REVIEW_PENDING
  PAYMENT_PENDING
}

model User {
  id               String        @id @default(cuid())
  name             String?
  email            String        @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  plainPassword    String?
  role             Role          @default(EMPLOYEE)
  position         String?
  capacity         Int           @default(4)
  archived         Boolean       @default(false)
  accounts         Account[]
  sessions         Session[]
  assignedProjects Project[]     @relation("AssignedProjects")
  tasks            Task[]
  activities       ActivityLog[]
  notifications    Notification[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id            String        @id @default(cuid())
  name          String
  phone         String
  email         String        @unique
  companyName   String
  paymentStatus PaymentStatus @default(PENDING)
  archived      Boolean       @default(false)
  projects      Project[]
  payments      Payment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Project {
  id                      String        @id @default(cuid())
  clientId                String
  assignedEmployeeId      String
  name                    String
  workType                WorkType
  status                  ProjectStatus @default(NEW)
  priority                Priority      @default(MEDIUM)
  startDate               DateTime
  deadline                DateTime
  notes                   String?       @db.Text
  reviewStatus            ReviewStatus  @default(PENDING_REVIEW)
  instagramPostCompleted  Boolean       @default(false)
  instagramStoryCompleted Boolean       @default(false)
  deliveryCompleted       Boolean       @default(false)
  taskCompletion          Int           @default(0)
  archived                Boolean       @default(false)
  websiteUrl              String?
  deployedUrl             String?
  renewalDate             DateTime?
  
  // 10-Step Tracker Fields
  currentStep             Int           @default(1)
  
  // Step 2: Requirement Collection
  businessName            String?
  logoUrl                 String?
  contactNumber           String?
  contactEmail            String?
  socialLinks             Json?
  location                String?
  packageType             String?
  domainNeed              Boolean       @default(false)
  totalAmount             Decimal       @db.Decimal(12, 2) @default(0)
  
  // Step 3: Advance Payment
  advanceAmount           Decimal       @db.Decimal(12, 2) @default(0)
  domainCharge            Decimal       @db.Decimal(12, 2) @default(0)
  
  // Step 4: Setup
  setupChecklist          Json?
  
  // Step 5: Testing
  testingChecklist        Json?
  
  // Step 6: Client Review
  clientChanges           String?       @db.Text
  clientApproved          Boolean       @default(false)
  
  // Step 7: Final Payment
  finalPaymentAmount      Decimal       @db.Decimal(12, 2) @default(0)
  finalPaymentMode        String?
  
  // Step 8: Connect Domain
  domainChecklist         Json?
  
  // Step 9: Renewal (handled by websiteUrl and renewalDate above)
  
  // Step 10 & 11: Social Posts & Admin
  socialPostsChecklist    Json?
  adminApproval           Boolean       @default(false)

  // Relations
  attachments             Attachment[]
  client                  Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedEmployee        User          @relation("AssignedProjects", fields: [assignedEmployeeId], references: [id])
  tasks                   Task[]
  payments                Payment[]
  activities              ActivityLog[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  assigneeId  String
  title       String
  completed   Boolean  @default(false)
  dueDate     DateTime?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User     @relation(fields: [assigneeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id             String   @id @default(cuid())
  clientId       String
  projectId      String?
  advancePayment Decimal  @default(0) @db.Decimal(12, 2)
  totalPayment   Decimal  @db.Decimal(12, 2)
  expenses       Decimal  @default(0) @db.Decimal(12, 2)
  employeeSalary Decimal  @default(0) @db.Decimal(12, 2)
  employeeSalaryPaid Boolean @default(false)
  amountPaid     Decimal  @default(0) @db.Decimal(12, 2)
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project        Project? @relation(fields: [projectId], references: [id])
  history        PaymentHistory[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PaymentHistory {
  id        String   @id @default(cuid())
  paymentId String
  amount    Decimal  @db.Decimal(12, 2)
  note      String?
  paidAt    DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(cuid())
  projectId String
  name      String
  url       String
  type      String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String?
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  scheduledFor DateTime?
  user      User?            @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorId   String?
  projectId String?
  action    String
  metadata  Json?
  actor     User?    @relation(fields: [actorId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}
